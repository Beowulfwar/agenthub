{
  "name": "agent-hub",
  "version": "0.1.0",
  "description": "CLI and MCP server for managing AI agent skills across Git and Google Drive backends",
  "type": "module",
  "bin": {
    "ahub": "./dist/bin/ahub.js"
  },
  "main": "./dist/src/index.js",
  "types": "./dist/src/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx bin/ahub.ts",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "googleapis": "^140.0.0",
    "gray-matter": "^4.0.3",
    "inquirer": "^9.0.0",
    "ora": "^8.0.0",
    "simple-git": "^3.25.0",
    "zod": "^3.25.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "ai",
    "agent",
    "skills",
    "mcp",
    "cli",
    "prompt-management"
  ],
  "license": "MIT"
}
